<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.seongqkim.economy-agent-backup</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>/Users/barq/developer/projects/economy-content-agent/deploy/backup_to_nas.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/barq/developer/projects/economy-content-agent</string>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>3</integer>
      <key>Minute</key>
      <integer>10</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/economy-agent-backup.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/economy-agent-backup.err.log</string>
  </dict>
</plist>
